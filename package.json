{
  "name": "@shadow-toolkit/core",
  "version": "2.0.0",
  "description": "Zero-dependency browser-native toolkit for sprite isolation, 2.5D physics, procedural audio, custom cursors, color palettes, and scroll animations.",
  "main": "dist/shadow-toolkit.cjs.js",
  "module": "dist/shadow-toolkit.esm.js",
  "browser": "dist/shadow-toolkit.umd.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs": "jsdoc -c jsdoc.conf.json -r .",
    "prepare": "npm run build"
  },
  "keywords": [
    "cursor",
    "animation",
    "physics",
    "holographic",
    "pixel",
    "scroll",
    "web-component",
    "ui-toolkit",
    "theme-manager"
  ],
  "author": "Shadow Toolkit Team",
  "license": "MIT",
  "homepage": "https://github.com/shadow-toolkit/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shadow-toolkit/core.git"
  },
  "bugs": {
    "url": "https://github.com/shadow-toolkit/core/issues"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rollup": "^3.10.0",
    "rollup-plugin-terser": "^7.0.2",
    "jsdoc": "^4.0.0"
  }
}